# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI / LLM ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── AWS (for production deployment) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL for production, SQLite (default) for local dev
DATABASE_URL=

# ── Bank Identity (for SAR filing) ─────────────────────────────────────────────
BANK_NAME=First National Bank
BANK_EIN=
BANK_RSSD=
BSA_OFFICER_NAME=
BSA_OFFICER_PHONE=
BSA_OFFICER_EMAIL=bsa@yourbank.com

# ── TMS Integration ─────────────────────────────────────────────────────────────
ACTIMIZE_API_URL=https://your-actimize-instance.com/api
ACTIMIZE_API_KEY=

# ── Watchlist Screening ─────────────────────────────────────────────────────────
WORLD_CHECK_API_KEY=
WORLD_CHECK_API_SECRET=
COMPLY_ADVANTAGE_API_KEY=
DOW_JONES_API_TOKEN=

# ── Core Banking ────────────────────────────────────────────────────────────────
CORE_BANKING_API_URL=https://your-core-banking-url.com/api/v1
CORE_BANKING_API_KEY=

# ── Case Management ──────────────────────────────────────────────────────────────
CASE_MGMT_API_URL=
CASE_MGMT_API_KEY=

# ── Notifications ───────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=compliance@yourbank.com

# ── Application ─────────────────────────────────────────────────────────────────
# Port is set by Railway automatically via $PORT env var
LOG_LEVEL=INFO
