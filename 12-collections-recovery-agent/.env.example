# Agent 12 — Collections & Recovery Agent
# Copy to .env and configure. ANTHROPIC_API_KEY is optional — demo mode works without it.

# LLM API key (optional — demo mode uses pre-computed narratives)
ANTHROPIC_API_KEY=sk-your-key-here

# Production: Aurora PostgreSQL LangGraph checkpoint store
POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/agent12

# Institution configuration
INSTITUTION_NAME=Your Institution Name
INSTITUTION_TYPE=BANK  # BANK, CREDIT_UNION, COLLECTIONS_AGENCY, FINTECH

# Compliance contacts
COLLECTIONS_COMPLIANCE_EMAIL=compliance@institution.com
LEGAL_COUNSEL_EMAIL=legal@institution.com

# Settlement thresholds (configurable per institution policy)
SETTLEMENT_HIGH_VALUE_THRESHOLD=10000  # USD — above this triggers HITL regardless of discount
SETTLEMENT_MAX_DISCOUNT_PCT=40         # Discount above this requires supervisor approval

# SCRA verification service (optional — demo uses fixture data)
SCRA_API_KEY=

# Streamlit port
PORT=8512
