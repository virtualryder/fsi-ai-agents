# ── Payments Compliance Agent — Environment Variables ─────────────────────────
#
# Copy this file to .env and fill in your values.
# The .env file is git-ignored — never commit secrets to version control.
#
# Production deployments: Use AWS Secrets Manager instead of a .env file.
# See docs/aws-deployment-guide.md for Secrets Manager configuration.

# ── Required: OpenAI API Key ──────────────────────────────────────────────────
# Required for LLM-powered nodes: dispute_analysis, compliance_analysis,
# resolution_drafting. Without this key, the app runs in demo mode.
ANTHROPIC_API_KEY=sk-your-openai-api-key-here

# ── Optional: LLM Configuration ───────────────────────────────────────────────
# Override the default model (claude-sonnet-4-6) or temperature (0).
# Temperature=0 is required for reproducible compliance outputs.
# CLAUDE_NARRATIVE_MODEL=claude-sonnet-4-6
# OPENAI_TEMPERATURE=0

# ── Optional: PostgreSQL for Production HITL ─────────────────────────────────
# Required for durable HITL review queue in production.
# MemorySaver (default) does not persist across restarts.
# POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/payments_compliance

# ── Optional: Institution Name (appears in customer notices) ─────────────────
# INSTITUTION_NAME=Community First Bank

# ── Optional: Streamlit Configuration ────────────────────────────────────────
# PORT=8510
