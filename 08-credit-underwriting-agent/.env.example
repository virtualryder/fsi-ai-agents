# OpenAI
ANTHROPIC_API_KEY=sk-...

# Institution Profile
INSTITUTION_NAME=First National Bank
INSTITUTION_TYPE=Community_Bank        # Community_Bank | Regional_Bank | Credit_Union | Broker_Dealer
INSTITUTION_CHARTER=National           # National | State | Federal_Credit_Union
PRIMARY_REGULATOR=OCC                  # OCC | FDIC | Federal_Reserve | NCUA

# Credit Underwriting Configuration
MAX_AUTO_APPROVE_AMOUNT=500000         # Applications above this always require human review
COMMITTEE_THRESHOLD=2000000            # Applications above this require credit committee
FAIR_LENDING_REVIEW_ENABLED=true       # Must be true in production — disabling requires CCO approval

# AWS (production)
# AWS_REGION=us-east-1
# DYNAMODB_AUDIT_TABLE=credit-underwriting-audit
# S3_RECORDS_BUCKET=credit-underwriting-records
# RDS_ENDPOINT=...
# KMS_KEY_ARN=arn:aws:kms:us-east-1:...  # For PII encryption at rest
