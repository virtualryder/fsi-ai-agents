# Required
ANTHROPIC_API_KEY=sk-...

# Institution Profile (used in gap analysis prompts)
INSTITUTION_TYPE=Commercial Bank
INSTITUTION_CHARTER=State-chartered, Federal Reserve member
PRIMARY_REGULATOR=Federal Reserve / State Banking Department

# Optional: Regulatory Feed APIs
# FEDERAL_REGISTER_API_KEY=your-key-here
# WOLTERS_KLUWER_API_KEY=your-key-here

# Optional: GRC System Integration
# GRC_API_BASE_URL=https://your-grc-system.internal
# GRC_API_TOKEN=your-token-here

# Optional: Policy Management System
# POLICY_MGMT_API_URL=https://your-policy-system.internal
# POLICY_MGMT_API_TOKEN=your-token

# Optional: Database (production persistence)
# DATABASE_URL=postgresql://user:password@host:5432/reg_change_mgmt

# Optional: Notification
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=compliance-agent@yourdomain.com
# SMTP_PASSWORD=your-password
