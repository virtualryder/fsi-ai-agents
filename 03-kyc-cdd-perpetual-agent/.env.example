# Required
OPENAI_API_KEY=sk-...

# Optional: KYC / Core Banking Integration
# KYC_API_BASE_URL=https://your-kyc-system.internal
# KYC_API_TOKEN=your-token-here

# Optional: Watchlist Screening
# SCREENING_API_URL=https://api.refinitiv.com/watchlist
# SCREENING_API_KEY=your-api-key

# Optional: Adverse Media
# ADVERSE_MEDIA_API_URL=https://api.lexisnexis.com/adverse-media
# ADVERSE_MEDIA_API_KEY=your-api-key

# Optional: Case Management
# CASE_MGMT_API_URL=https://your-case-system.internal
# CASE_MGMT_API_TOKEN=your-token

# Optional: Database (production persistence)
# DATABASE_URL=postgresql://user:password@host:5432/kyc_reviews
