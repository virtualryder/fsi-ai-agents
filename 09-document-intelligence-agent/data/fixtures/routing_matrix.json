  "hitl_decision_options": [
    {
      "decision": "APPROVE_AND_ROUTE",
      "display_name": "Approve and Route",
      "description": "Extraction is accurate. Route document to target agents as-is.",
      "downstream_action": "enrichment → output_packaging → downstream_agents"
    },
    {
      "decision": "CORRECT_AND_ROUTE",
      "display_name": "Correct and Route",
      "description": "Apply reviewer's field corrections, then route to target agents.",
      "downstream_action": "correction_merge → enrichment → output_packaging → downstream_agents"
    },
    {
      "decision": "REJECT",
      "display_name": "Reject",
      "description": "Document is fraudulent, unreadable, or otherwise unprocessable. Mark REJECTED and close.",
      "downstream_action": "audit_finalize (REJECTED status)"
    },
    {
      "decision": "REQUEST_RESUBMIT",
      "display_name": "Request Resubmission",
      "description": "Document is incomplete or incorrect. Notify submitter to resubmit.",
      "downstream_action": "audit_finalize (PENDING_RESUBMIT status) + notification to source_system"
    }
  ],

  "confidence_tiers": [
    {
      "tier": "HIGH",
      "threshold": "≥ 0.85",
      "action": "Auto-route to downstream agents",
      "hitl": false
    },
    {
      "tier": "MEDIUM",
      "threshold": "0.65 – 0.84",
      "action": "Auto-route with low-confidence fields flagged for downstream agent awareness",
      "hitl": false
    },
    {
      "tier": "LOW",
      "threshold": "0.40 – 0.64",
      "action": "HITL required — human review before routing",
      "hitl": true
    },
    {
      "tier": "UNCERTAIN",
      "threshold": "< 0.40",
      "action": "HITL required — likely UNKNOWN document type",
      "hitl": true
    }
