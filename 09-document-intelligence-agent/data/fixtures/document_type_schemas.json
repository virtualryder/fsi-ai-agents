      "cost_of_goods_sold",
      "total_deductions",
      "net_income",
      "accumulated_earnings",
      "total_assets",
      "total_liabilities"
    ],
    "pii_fields": {
      "corporation_ein": "EIN",
      "corporation_name": "NAME"
    },
    "validation_rules": {
      "tax_year": {"type": "integer", "min": 2010, "max": 2030},
      "total_income": {"type": "numeric"},
      "taxable_income": {"type": "numeric"}
    },
    "regulatory_basis": ["IRS regulations", "OCC Comptroller's Handbook — Commercial RE Lending"]
  },

  "FINANCIAL_STATEMENT": {
    "description": "Business financial statement — Balance Sheet, Income Statement, or Cash Flow Statement. May be audited, reviewed, compiled, or internally prepared. Quality tier (audited > reviewed > compiled > internal) affects underwriting confidence.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "statement_type",
      "period_end_date",
      "entity_name",
      "total_revenue",
      "net_income",
      "total_assets",
      "total_liabilities"
    ],
    "optional_fields": [
      "total_equity",
      "operating_income",
      "ebitda",
      "current_assets",
      "current_liabilities",
      "long_term_debt",
      "cash_and_equivalents",
      "statement_quality",
      "cpa_firm_name",
      "auditor_opinion"
    ],
    "pii_fields": {
      "entity_name": "NAME"
    },
    "validation_rules": {
      "period_end_date": {"type": "date", "format": "YYYY-MM-DD"},
      "statement_type": {"allowed_values": ["BALANCE_SHEET", "INCOME_STATEMENT", "CASH_FLOW", "COMBINED"]},
      "statement_quality": {"allowed_values": ["AUDITED", "REVIEWED", "COMPILED", "INTERNAL"]}
    },
    "regulatory_basis": ["GAAP", "OCC Comptroller's Handbook", "SBA SOP 50-10"]
  },

  "BANK_STATEMENT": {
    "description": "Bank account statement showing deposits, withdrawals, and balances over a period (typically 2–3 months). Used in underwriting to verify income, assess cash flow consistency, and detect NSF/overdraft patterns that may indicate financial stress.",
    "downstream_agents": ["08-credit-underwriting", "01-financial-crime-investigation"],
    "required_fields": [
      "account_number_last4",
      "account_holder_name",
      "institution_name",
      "statement_period_start",
      "statement_period_end",
      "beginning_balance",
      "ending_balance",
      "total_deposits",
      "total_withdrawals"
    ],
    "optional_fields": [
      "average_daily_balance",
      "nsf_count",
      "overdraft_count",
      "large_deposits_flagged",
      "wire_transfers_in",
      "wire_transfers_out",
      "cash_deposits_count",
      "account_type"
    ],
    "pii_fields": {
      "account_number_last4": "ACCOUNT_NUMBER",
      "account_holder_name": "NAME"
    },
    "validation_rules": {
      "statement_period_start": {"type": "date", "format": "YYYY-MM-DD"},
      "statement_period_end": {"type": "date", "format": "YYYY-MM-DD"},
      "beginning_balance": {"type": "numeric"},
      "ending_balance": {"type": "numeric"}
    },
    "regulatory_basis": ["BSA/AML — unusual cash activity", "Fannie Mae B3-4.2 — asset verification"]
  },

  "SBA_FORM_1919": {
    "description": "SBA Form 1919 — Borrower Information Form. Required for all SBA 7(a) and 504 loan applications. Captures ownership structure, criminal history certifications, and certifications regarding existing SBA debt. Must be signed by all 20%+ owners.",
    "downstream_agents": ["08-credit-underwriting", "03-kyc-cdd-perpetual"],
    "required_fields": [
      "business_name",
      "business_ein",
      "loan_amount_requested",
      "loan_purpose",
      "owners_listed",
      "criminal_history_certification",
      "existing_sba_debt_flag"
    ],
    "optional_fields": [
      "naics_code",
      "business_type",
      "years_in_business",
      "veteran_owned_flag",
      "woman_owned_flag",
      "minority_owned_flag",
      "hub_zone_flag"
    ],
    "pii_fields": {
      "business_ein": "EIN",
      "owners_listed": "NAME"
    },
    "validation_rules": {
      "loan_amount_requested": {"type": "numeric", "min": 1, "max": 5000000},
      "criminal_history_certification": {"type": "boolean"},
      "existing_sba_debt_flag": {"type": "boolean"}
    },
    "regulatory_basis": ["SBA SOP 50-10", "13 CFR Part 120", "Bank Secrecy Act CIP requirements"]
  },

  "SBA_FORM_1920": {
    "description": "SBA Form 1920 — Lender's Application for Loan Guaranty. Completed by the lender (not the borrower) as part of the SBA guaranty application package. Certifies the lender's underwriting decision and compliance with SBA eligibility requirements.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "lender_name",
      "lender_sba_number",
      "borrower_name",
      "loan_amount",
      "sba_guaranty_requested",
      "collateral_description",
      "lender_decision",
      "underwriter_certification"
    ],
    "optional_fields": [
      "loan_term_months",
      "interest_rate",
      "environmental_review_flag",
      "injection_amount",
      "standby_agreement_flag"
    ],
    "pii_fields": {
      "borrower_name": "NAME"
    },
    "validation_rules": {
      "loan_amount": {"type": "numeric", "min": 1, "max": 5000000},
      "sba_guaranty_requested": {"type": "numeric", "min": 0, "max": 3750000},
      "lender_decision": {"allowed_values": ["APPROVE", "DECLINE", "REFER"]}
    },
    "regulatory_basis": ["SBA SOP 50-10", "13 CFR Part 120"]
  },

  "SWIFT_MT103": {
    "description": "SWIFT MT103 — Single Customer Credit Transfer. International wire transfer message between banks. Carries payer and payee details, amounts, currency, and correspondent bank routing. High priority for AML/transaction monitoring due to cross-border cash movement. Always routed to financial crime investigation and fraud detection agents.",
    "downstream_agents": ["01-financial-crime-investigation", "04-fraud-detection"],
    "required_fields": [
      "transaction_reference_number",
      "value_date",
      "currency",
      "amount",
      "ordering_customer_name",
      "ordering_customer_account",
      "beneficiary_name",
      "beneficiary_account",
      "beneficiary_bank_bic",
      "ordering_bank_bic"
    ],
    "optional_fields": [
      "remittance_information",
      "correspondent_bank_bic",
      "charges_indicator",
      "regulatory_reporting",
      "originator_address",
      "beneficiary_address",
      "sender_reference"
    ],
    "pii_fields": {
      "ordering_customer_account": "ACCOUNT_NUMBER",
      "beneficiary_account": "ACCOUNT_NUMBER",
      "ordering_customer_name": "NAME",
      "beneficiary_name": "NAME"
    },
    "validation_rules": {
      "value_date": {"type": "date", "format": "YYYY-MM-DD"},
      "amount": {"type": "numeric", "min": 0.01},
      "currency": {"type": "string", "length": 3, "pattern": "^[A-Z]{3}$"},
      "ordering_bank_bic": {"type": "string", "pattern": "^[A-Z]{6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3})?$"},
      "beneficiary_bank_bic": {"type": "string", "pattern": "^[A-Z]{6}[A-Z2-9][A-NP-Z0-9]([A-Z0-9]{3})?$"}
    },
    "high_risk_screening": {
      "ctr_threshold_usd": 10000,
      "structuring_detection": true,
      "ofac_screening_required": true,
      "high_risk_country_check": true
    },
    "regulatory_basis": ["BSA/AML", "31 CFR Part 1010", "OFAC SDN/OFAC", "Reg GG — UIGEA", "FATF Recommendations"]
  },

  "SWIFT_MT202": {
    "description": "SWIFT MT202 — General Financial Institution Transfer. Bank-to-bank transfer (no end-customer named in primary fields). Used for interbank settlements, nostro account funding, and correspondent banking. High AML risk when beneficial ownership of the underlying transaction is obscured.",
    "downstream_agents": ["01-financial-crime-investigation"],
    "required_fields": [
      "transaction_reference_number",
      "value_date",
      "currency",
      "amount",
      "ordering_institution_bic",
      "beneficiary_institution_bic",
      "account_with_institution"
    ],
    "optional_fields": [
      "sender_correspondent_bic",
      "receiver_correspondent_bic",
      "transaction_type_code",
      "related_reference",
      "originator",
      "beneficiary_customer"
    ],
    "pii_fields": {
      "originator": "NAME",
      "beneficiary_customer": "NAME"
    },
    "validation_rules": {
      "value_date": {"type": "date", "format": "YYYY-MM-DD"},
      "amount": {"type": "numeric", "min": 0.01},
      "currency": {"type": "string", "length": 3, "pattern": "^[A-Z]{3}$"}
    },
    "high_risk_screening": {
      "ctr_threshold_usd": 10000,
      "correspondent_bank_risk_check": true,
      "ofac_screening_required": true
    },
    "regulatory_basis": ["BSA/AML", "OFAC", "FATF Recommendation 16 (Wire Transfer Rule)"]
  },

  "WIRE_INSTRUCTION": {
    "description": "Wire transfer instructions document — typically a PDF or Word document submitted by a customer to initiate a domestic or international wire. HIGH FRAUD RISK: Business Email Compromise (BEC) attacks frequently use spoofed or altered wire instructions to redirect payments. Always requires verification against prior instructions on file.",
    "downstream_agents": ["04-fraud-detection", "01-financial-crime-investigation"],
    "required_fields": [
      "beneficiary_name",
      "beneficiary_bank_name",
      "beneficiary_account_last4",
      "routing_number",
      "wire_amount",
      "wire_currency",
      "wire_purpose"
    ],
    "optional_fields": [
      "beneficiary_address",
      "beneficiary_bank_swift",
      "intermediary_bank_name",
      "intermediary_bank_swift",
      "memo_reference",
      "requester_name",
      "request_date"
    ],
    "pii_fields": {
      "beneficiary_name": "NAME",
      "beneficiary_account_last4": "ACCOUNT_NUMBER",
      "routing_number": "ROUTING_NUMBER",
      "requester_name": "NAME"
    },
    "validation_rules": {
      "wire_amount": {"type": "numeric", "min": 0.01},
      "routing_number": {"type": "string", "length": 9, "pattern": "^0[0-9]{8}$"},
      "wire_currency": {"type": "string", "length": 3}
    },
    "fraud_screening": {
      "bec_risk": "HIGH",
      "verify_against_prior_instructions": true,
      "callback_verification_required_above_usd": 25000
    },
    "regulatory_basis": ["BSA/AML", "NACHA Operating Rules (ACH comparison)", "UCC Article 4A"]
  },

  "TRADE_CONFIRMATION": {
    "description": "Trade confirmation document for securities, derivatives, or FX transactions. Confirms the economic terms of an executed trade between counterparties. Regulated under SEC, FINRA, and CFTC depending on instrument type. Used by trading surveillance to detect wash trading, front-running, and spoofing.",
    "downstream_agents": ["07-trading-surveillance"],
    "required_fields": [
      "trade_date",
      "settlement_date",
      "instrument_identifier",
      "instrument_type",
      "quantity",
      "price",
      "notional_value",
      "counterparty_name",
      "trader_id",
      "account_number_last4",
      "buy_sell_indicator"
    ],
    "optional_fields": [
      "instrument_name",
      "isin",
      "cusip",
      "lei",
      "currency",
      "commission",
      "executing_broker",
      "clearing_broker",
      "settlement_currency",
      "fx_rate",
      "strategy_code"
    ],
    "pii_fields": {
      "counterparty_name": "NAME",
      "account_number_last4": "ACCOUNT_NUMBER",
      "trader_id": "EMPLOYEE_ID"
    },
    "validation_rules": {
      "trade_date": {"type": "date", "format": "YYYY-MM-DD"},
      "settlement_date": {"type": "date", "format": "YYYY-MM-DD"},
      "quantity": {"type": "numeric", "min": 0},
      "price": {"type": "numeric", "min": 0},
      "notional_value": {"type": "numeric", "min": 0},
      "buy_sell_indicator": {"allowed_values": ["BUY", "SELL", "SHORT_SELL"]}
