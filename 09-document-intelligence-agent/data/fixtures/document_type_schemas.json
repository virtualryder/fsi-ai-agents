    ],
    "pii_fields": {
      "partnership_ein": "EIN",
      "partnership_name": "NAME"
    },
    "validation_rules": {
      "tax_year": {"type": "integer", "min": 2010, "max": 2030},
      "ordinary_business_income": {"type": "numeric"},
      "total_revenue": {"type": "numeric", "min": 0}
    },
    "regulatory_basis": ["IRS regulations", "Fannie Mae B3-3.4", "SBA SOP 50-10"]
  },

  "TAX_RETURN_1120": {
    "description": "IRS Form 1120 — U.S. Corporation Income Tax Return. Used for C-corporation borrowers. Analysts use to assess entity income, debt service coverage, and global cash flow when a corporate guarantor is involved.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "tax_year",
      "corporation_name",
      "corporation_ein",
      "total_income",
      "taxable_income",
      "total_tax"
    ],
    "optional_fields": [
