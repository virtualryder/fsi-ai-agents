  "GOVERNMENT_ID": {
    "description": "Government-issued identity document — passport, driver's license, national ID card, or military ID. ALWAYS requires human review before processing because: (1) it contains highly sensitive PII including biometric data, (2) it is the primary KYC/CDD identity verification document, (3) forgery detection requires human judgment on document security features. Passport numbers are never extracted — the agent records PASSPORT_PRESENT only.",
    "downstream_agents": ["03-kyc-cdd-perpetual"],
    "always_hitl": true,
    "required_fields": [
      "document_subtype",
      "issuing_country",
      "expiration_date",
      "id_holder_name",
      "date_of_birth"
    ],
    "optional_fields": [
      "issuing_state_province",
      "id_number_present_flag",
      "gender",
      "nationality",
      "mrz_detected_flag"
    ],
    "pii_fields": {
      "id_holder_name": "NAME",
      "date_of_birth": "DOB",
      "id_number_present_flag": "PASSPORT"
    },
    "extraction_constraints": {
      "id_number": "NEVER_EXTRACT — record id_number_present_flag=true only",
      "passport_number": "NEVER_EXTRACT — record PASSPORT_PRESENT only",
      "ssn_on_id": "EXTRACT_LAST_4_ONLY"
    },
    "validation_rules": {
      "expiration_date": {"type": "date", "format": "YYYY-MM-DD"},
      "date_of_birth": {"type": "date", "format": "YYYY-MM-DD"},
      "document_subtype": {"allowed_values": ["PASSPORT", "DRIVERS_LICENSE", "NATIONAL_ID", "MILITARY_ID", "RESIDENT_ALIEN_CARD"]}
    },
    "regulatory_basis": ["BSA CIP (31 CFR 1020.220)", "FinCEN Customer Due Diligence Rule", "USA PATRIOT Act Section 326"]
  },

