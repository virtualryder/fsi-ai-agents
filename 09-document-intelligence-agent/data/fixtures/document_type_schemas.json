{
  "_comment": "Document Type Schemas — Document Intelligence Agent (Agent 09)",
  "_description": "This file defines the required and optional extraction fields for each of the 25 document types the agent can process. Each schema entry includes field definitions, validation rules, and the downstream agents that consume the extracted data. When the field_extraction_node in nodes.py requests field extraction from the LLM, it loads the relevant schema from this file and passes the required/optional field lists in the extraction prompt. Python then validates the LLM's response against the validation_rules in this file.",
  "_security_note": "Fields marked pii_type will be masked in the audit trail and in the output payload before it is sent to downstream agents. The LLM extraction prompt instructs the model to return only masked versions of these fields (e.g., SSN last 4, PASSPORT_PRESENT). Python regex-based PII detection runs before LLM extraction as a defense-in-depth measure.",
  "_schema_version": "1.0.0",

  "LOAN_APPLICATION_RESIDENTIAL": {
    "description": "Consumer mortgage loan application. Covers Fannie Mae Form 1003 and equivalent GSE applications for purchase, refinance, and home equity. Regulated under ECOA, Reg B, HMDA, and TILA/Reg Z.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "applicant_name",
      "applicant_ssn_last4",
      "loan_amount_requested",
      "property_address",
      "property_type",
      "loan_purpose",
      "annual_income",
      "monthly_debt_payments",
      "credit_score"
    ],
    "optional_fields": [
      "co_applicant_name",
      "co_applicant_ssn_last4",
      "employment_status",
      "employer_name",
      "years_employed",
      "property_value",
      "down_payment_amount",
      "loan_term_years",
      "interest_rate_requested",
      "source_of_funds",
      "race_ethnicity_flag",
      "hmda_action_taken"
    ],
    "pii_fields": {
      "applicant_ssn_last4": "SSN",
      "co_applicant_ssn_last4": "SSN",
      "applicant_name": "NAME",
      "co_applicant_name": "NAME",
      "property_address": "ADDRESS"
    },
    "validation_rules": {
      "loan_amount_requested": {"type": "numeric", "min": 1000, "max": 50000000},
      "credit_score": {"type": "integer", "min": 300, "max": 850},
      "annual_income": {"type": "numeric", "min": 0},
      "loan_purpose": {"allowed_values": ["PURCHASE", "REFINANCE", "CASH_OUT_REFINANCE", "HOME_EQUITY", "CONSTRUCTION", "HOME_IMPROVEMENT"]}
    },
    "regulatory_basis": ["ECOA/Reg B", "HMDA", "TILA/Reg Z", "RESPA", "FCRA"]
  },

  "LOAN_APPLICATION_COMMERCIAL": {
    "description": "Commercial real estate (CRE) or business loan application. Covers term loans, lines of credit, and construction financing for business entities. Regulated under Reg B (business credit), CRA, and SBA regulations when applicable.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "borrower_legal_name",
      "borrower_ein",
      "loan_amount_requested",
      "loan_purpose",
      "collateral_description",
      "collateral_value",
      "annual_revenue",
      "years_in_business"
    ],
    "optional_fields": [
      "guarantor_name",
      "guarantor_ssn_last4",
      "property_address",
      "property_type",
      "noi",
      "dscr",
      "ltv",
      "global_cash_flow",
      "existing_debt_obligations",
      "number_of_employees",
      "industry_naics_code",
      "sba_program"
    ],
    "pii_fields": {
      "borrower_ein": "EIN",
      "guarantor_ssn_last4": "SSN",
      "guarantor_name": "NAME"
    },
    "validation_rules": {
      "loan_amount_requested": {"type": "numeric", "min": 25000},
      "annual_revenue": {"type": "numeric", "min": 0},
      "ltv": {"type": "float", "min": 0.0, "max": 1.0},
      "dscr": {"type": "float", "min": 0.0}
    },
    "regulatory_basis": ["Reg B (business credit)", "CRA", "SBA 7(a)/504", "HMDA (if CRE)"]
  },

  "PROPERTY_APPRAISAL": {
    "description": "Real estate appraisal report prepared by a licensed appraiser. Must conform to USPAP (Uniform Standards of Professional Appraisal Practice). Used as collateral valuation input for residential and commercial underwriting.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "property_address",
      "appraised_value",
      "appraisal_date",
      "appraiser_name",
      "appraiser_license_number",
      "appraisal_method",
      "effective_date"
    ],
    "optional_fields": [
      "comparable_sales",
      "neighborhood_description",
      "condition_rating",
      "square_footage",
      "lot_size",
      "year_built",
      "zoning",
      "environmental_issues_flag",
      "flood_zone"
    ],
    "pii_fields": {
      "property_address": "ADDRESS",
      "appraiser_name": "NAME"
    },
    "validation_rules": {
      "appraised_value": {"type": "numeric", "min": 1},
      "appraisal_date": {"type": "date", "format": "YYYY-MM-DD"},
      "appraisal_method": {"allowed_values": ["SALES_COMPARISON", "INCOME_APPROACH", "COST_APPROACH", "HYBRID", "DESKTOP"]}
    },
    "regulatory_basis": ["USPAP", "FIRREA", "Interagency Appraisal Guidelines"]
  },

  "TAX_RETURN_1040": {
    "description": "IRS Form 1040 — Individual Income Tax Return. Primary income documentation for residential mortgage underwriting. Fannie Mae guidelines require 2 years of 1040s for self-employed borrowers.",
    "downstream_agents": ["08-credit-underwriting"],
    "required_fields": [
      "tax_year",
      "taxpayer_name",
      "taxpayer_ssn_last4",
      "adjusted_gross_income",
      "total_income",
      "filing_status"
    ],
    "optional_fields": [
      "spouse_name",
      "spouse_ssn_last4",
      "wages_salaries",
      "business_income_schedule_c",
      "rental_income_schedule_e",
      "partnership_income_schedule_k1",
      "total_tax",
      "tax_due_or_refund",
      "amended_return_flag"
    ],
    "pii_fields": {
      "taxpayer_ssn_last4": "SSN",
      "spouse_ssn_last4": "SSN",
      "taxpayer_name": "NAME",
      "spouse_name": "NAME"
    },
    "validation_rules": {
      "tax_year": {"type": "integer", "min": 2010, "max": 2030},
      "adjusted_gross_income": {"type": "numeric"},
      "filing_status": {"allowed_values": ["SINGLE", "MARRIED_FILING_JOINTLY", "MARRIED_FILING_SEPARATELY", "HEAD_OF_HOUSEHOLD", "QUALIFYING_WIDOW"]}
    },
    "regulatory_basis": ["IRS regulations", "Fannie Mae Selling Guide B3-3.1", "FHA Handbook 4000.1"]
  },

