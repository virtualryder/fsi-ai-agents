# Document Intelligence Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must NEVER be committed.
#
# In production (AWS ECS), these variables are injected by the ECS
# task definition from AWS Secrets Manager. The .env file is only
# used for local development and demos.
# ============================================================

# ── Required: OpenAI API Key ─────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
# Without this key, the app runs in DEMO MODE (pre-computed outputs).
ANTHROPIC_API_KEY=sk-your-openai-api-key-here

# ── Optional: OpenAI Model Override ──────────────────────────
# Default: claude-sonnet-4-6 (best accuracy for financial document classification)
# Override with claude-haiku-4-5 for lower cost in development.
# CLAUDE_NARRATIVE_MODEL=claude-sonnet-4-6

# ── Optional: LangGraph PostgreSQL Checkpointer ───────────────
# Required for production HITL persistence.
# Format: postgresql://user:password@host:5432/database
# Leave empty to use MemorySaver (in-memory, development only).
# DATABASE_URL=postgresql://agent09:password@localhost:5432/agent09_db

# ── Optional: Logging ────────────────────────────────────────
# Set to WARNING in production to suppress verbose LangGraph logs.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# ── Optional: Document Size Limits ───────────────────────────
# Maximum document size in bytes. Default: 10MB (10485760).
# MAX_DOCUMENT_SIZE_BYTES=10485760

# ── Optional: SWIFT High-Risk Country Override ───────────────
# Comma-separated list of ISO 3166-1 alpha-2 country codes
# (first 2 characters of BIC) to add to the high-risk screening list.
# The default list is defined in nodes.py.
# ADDITIONAL_HIGH_RISK_COUNTRIES=KP,IR,CU

# ── Optional: Streamlit Port ─────────────────────────────────
# Default: 8509
# STREAMLIT_PORT=8509
