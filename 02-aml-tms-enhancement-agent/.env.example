# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aml_tms_scoring

# ── TMS Integration ───────────────────────────────────────────────────────────
# Supported vendors: actimize | verafin | nice | oracle_mantas
TMS_VENDOR=actimize
TMS_API_KEY=
TMS_API_URL=https://actimize.yourbank.com/api/v1

# ── Core Banking ──────────────────────────────────────────────────────────────
CORE_BANKING_API_URL=https://corebanking.yourbank.com/api/v1
CORE_BANKING_API_KEY=

# ── Scoring Thresholds (0-100 FP probability) ─────────────────────────────────
# Alert is SUPPRESSED when FP probability >= this value
SUPPRESS_THRESHOLD=85
# Alert priority is DOWNGRADED when FP probability >= this value
DOWNGRADE_THRESHOLD=60
# Alert is ESCALATED (fast-tracked) when FP probability <= this value
ESCALATE_THRESHOLD=15

# ── Downstream Investigation Agent ────────────────────────────────────────────
# SQS queue URL where surviving alerts are forwarded
INVESTIGATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/aml-investigation-alerts

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
