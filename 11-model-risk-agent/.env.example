# Agent 11 — Model Risk Management Agent
# Copy to .env and configure. OPENAI_API_KEY is optional — demo mode works without it.

# LLM API key (optional — demo mode uses pre-computed narratives)
OPENAI_API_KEY=sk-your-key-here

# Production: Aurora PostgreSQL LangGraph checkpoint store
# IMPORTANT: Aurora must be configured with log_statement=none to prevent
# validation findings and model parameters from appearing in database query logs.
# This is a required pre-go-live item — documented in docs/aws-deployment-guide.md.
POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/agent11

# Institution configuration
INSTITUTION_NAME=Your Institution Name
INSTITUTION_TYPE=BANK  # BANK, CREDIT_UNION, BROKER_DEALER, FINTECH

# Model risk officer contact (used in validation report routing)
MRO_EMAIL=mro@institution.com
CRO_EMAIL=cro@institution.com

# Streamlit port
PORT=8511
